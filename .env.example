# ---------------------------------------------------------------------------
# Signal — environment contract
#
# Copy to `.env.local` (gitignored) and fill in. NEVER commit `.env.local`.
# Every var below must also be set in Vercel → Project → Settings → Environment
# Variables, scoped to ALL environments (Production, Preview, Development).
#
# Scoping a var to Production only will crash Preview builds at module load.
# ---------------------------------------------------------------------------

# --- Firebase client (safe to expose; these identify the project, not authenticate) ---
# From Firebase console → Project settings → Your apps → SDK setup and configuration.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (SECRET — server only, never NEXT_PUBLIC_) ---
# From Firebase console → Project settings → Service accounts → Generate new private key.
# PRIVATE_KEY contains literal \n escapes; keep the surrounding double quotes.
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Meta Graph API (SECRET) ---
# developers.facebook.com → your app → Settings → Basic.
META_APP_ID=
META_APP_SECRET=
# Arbitrary string you choose; must match the value entered in the Meta webhook UI.
META_WEBHOOK_VERIFY_TOKEN=

# --- Cloudinary (SECRET) ---
# cloudinary.com → Dashboard. API_SECRET signs uploads server-side.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Resend (SECRET) ---
RESEND_API_KEY=
# Must be a verified sending domain in Resend, e.g. "Signal <noreply@yourdomain.com>"
EMAIL_FROM=

# --- Anthropic (SECRET — server-side calls only, never shipped to the browser) ---
ANTHROPIC_API_KEY=

# --- App ---
# Absolute origin, no trailing slash. Used to build OAuth redirect URIs, public
# report links and one-click approval links, so it must match the real origin.
APP_URL=http://localhost:3000

# 32-byte hex (64 chars). Encrypts Meta tokens at rest (AES-256-GCM).
# Generate: openssl rand -hex 32
# Rotating this invalidates every stored connection token — all brands reconnect.
TOKEN_ENCRYPTION_KEY=

# Shared secret for Vercel Cron auth; cron routes reject requests without it.
# Generate: openssl rand -hex 32
CRON_SECRET=

# --- Stripe (OPTIONAL) ---
# Billing is a drop-in: leave these blank and the app runs on the free plan with
# the Billing screen showing an "unconfigured" state. Set all three to enable
# upgrades. STRIPE_PRICE_PRO is the recurring Price id for the Pro plan; the
# webhook secret comes from the Stripe dashboard endpoint for /api/webhooks/stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=

# --- Feature flags ---
# true  → MockAdapter: realistic fake data, no Meta calls. Demoable pre-App-Review.
# false → live Meta Graph API.
USE_MOCK_ADAPTERS=true

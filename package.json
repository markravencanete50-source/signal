{
  "name": "signal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "emulators": "firebase emulators:start --only auth,firestore",
    "test:unit": "vitest run tests/unit",
    "test:rules": "firebase emulators:exec --only firestore --project signal-test \"vitest run --dir tests/rules\"",
    "test:integration": "firebase emulators:exec --only firestore --project signal-integration \"vitest run --no-file-parallelism tests/integration\""
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "cloudinary": "^2.10.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^5.23.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "stripe": "^22.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "firebase-tools": "^15.24.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "jwks-rsa": {
      "jose": "^5.9.6"
    }
  }
}

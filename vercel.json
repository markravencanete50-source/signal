{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/publish",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/sync",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/digest",
      "schedule": "0 8 * * *"
    }
  ]
}
